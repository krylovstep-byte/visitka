{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "static-site",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "require('http').createServer((req,res)=>{const fs=require('fs'),path=require('path');let f=path.join('C:\\\\Users\\\\Степан\\\\Desktop\\\\stepankrylov-site',req.url==='/'?'index.html':req.url);fs.readFile(f,(e,d)=>{if(e){res.writeHead(404);res.end();}else{const m={'html':'text/html','css':'text/css','js':'application/javascript','png':'image/png','webp':'image/webp','ttf':'font/ttf'};const ext=f.split('.').pop();res.writeHead(200,{'Content-Type':m[ext]||'text/plain'});res.end(d);}});}).listen(3000,()=>console.log('OK'))"],
      "port": 3000
    }
  ]
}
